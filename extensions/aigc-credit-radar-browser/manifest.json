{
  "manifest_version": 3,
  "name": "AIGC Credit Radar Connector",
  "version": "0.1.0",
  "description": "Send visible AIGC credit balances from your signed-in browser tab to the local Credit Radar helper.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "http://127.0.0.1:8787/*",
    "https://www.lovart.ai/*",
    "https://lovart.ai/*",
    "https://app.tapnow.ai/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.lovart.ai/*",
        "https://lovart.ai/*",
        "https://app.tapnow.ai/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Send credits to Radar",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
